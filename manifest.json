{
  "manifest_version": 3,
  "name": "MindMark companion",
  "version": "1.0.0",
  "homepage_url": "https://mindmark.tech",
  "description": "Bookmark your mind's exact state. The ultimate context-preservation tool.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["https://mindmark.tech/*"],
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mindmark.tech/*", "http://localhost:3000/*"],
      "js": ["content.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
